rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: portfolios
    // Fields:
    //   - brand: string (required)
    //   - product: string (required)
    //   - type: string (required, enum: ['신규 제작', '리뉴얼'])
    //   - images: list of strings (required, base64)
    //   - link: string (required, URL)
    //   - createdAt: timestamp (required)
    //
    // Collection: brandLogos
    // Fields:
    //   - url: string (required, base64)
    //   - createdAt: timestamp (required)
    //
    // Collection: inquiries
    // Fields:
    //   - name: string (required)
    //   - phone: string (required)
    //   - brand: string (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((request.auth.token.email == "po8822@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isValidPortfolio(data) {
      return data.keys().hasAll(['brand', 'product', 'type', 'images', 'link']) &&
             data.brand is string && data.brand.size() > 0 && data.brand.size() < 100 &&
             data.product is string && data.product.size() > 0 && data.product.size() < 100 &&
             data.type in ['신규 제작', '리뉴얼'] &&
             data.images is list && data.images.size() > 0 && data.images.size() <= 10 &&
             data.link is string && data.link.size() < 500 &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidLogo(data) {
      return data.keys().hasAll(['url', 'createdAt']) &&
             data.url is string && data.url.size() > 0 &&
             data.createdAt is timestamp;
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'phone', 'brand', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() < 30 &&
             data.brand is string && data.brand.size() > 0 && data.brand.size() < 100 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /portfolios/{portfolioId} {
      allow read: if true; // Publicly readable for the website
      allow create: if isAdmin() && isValidPortfolio(request.resource.data);
      allow update: if isAdmin() && isValidPortfolio(request.resource.data);
      allow delete: if isAdmin();
    }

    match /brandLogos/{logoId} {
      allow read: if true; // Publicly readable for the website
      allow create: if isAdmin() && isValidLogo(request.resource.data);
      allow update: if isAdmin() && isValidLogo(request.resource.data);
      allow delete: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow create: if true; // Anyone can submit an inquiry
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
